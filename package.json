{
  "name": "wasp-hls",
  "version": "0.4.2",
  "description": "WebAssembly HLS Player Proof Of Concept",
  "type": "module",
  "main": "build/es6/ts-main/index.js",
  "types": "build/es6/ts-main/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/es6/ts-main/index.d.ts",
      "default": "./build/es6/ts-main/index.js"
    },
    "./wasm": {
      "types": "./build/embedded/wasm.d.ts",
      "default": "./build/embedded/wasm.js"
    },
    "./worker": {
      "types": "./build/embedded/worker.d.ts",
      "default": "./build/embedded/worker.js"
    }
  },
  "files": [
    "build/",
    "doc/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run generate:wasm-abi && npm run clean && npm run build:wasm && npm run build:worker && npm run build:main",
    "build:demo": "esbuild demo/src/index.tsx --bundle --outfile=build/demo.js",
    "build:demo:release": "esbuild demo/src/index.tsx --bundle --outfile=build/demo.js --minify",
    "build:demo:watch": "esbuild demo/src/index.tsx --bundle --outfile=build/demo.js --watch",
    "build:main": "esbuild src/ts-main/index.ts --bundle --outfile=build/main.js",
    "build:main:es6": "rm -rf build/es6 && tsc -p src/ts-main/tsconfig.json --outDir \"./build/es6\"",
    "build:main:release": "esbuild src/ts-main/index.ts --bundle --outfile=build/main.js --minify",
    "build:release": "npm run generate:wasm-abi && npm run clean && npm run build:wasm:release && npm run build:worker:release && npm run build:main:release",
    "build:wasm": "npm run generate:wasm-abi && npm run compile:rs && npm run move:wasm && npm run check:wasm-abi",
    "build:wasm:release": "npm run generate:wasm-abi && npm run compile:rs:release && npm run move:wasm:release && npm run check:wasm-abi && node scripts/wasm-strip.js build/wasp_hls_bg.wasm",
    "build:worker": "esbuild src/ts-worker/index.ts --bundle --outfile=build/worker.js",
    "build:worker:release": "esbuild src/ts-worker/index.ts --bundle --outfile=build/worker.js --minify",
    "check": "npm run generate:wasm-abi && npm run types && npm run lint",
    "check:demo": "npm run types:demo && npm run lint:demo",
    "check:main": "npm run types:main && npm run lint:main",
    "check:worker": "npm run types:worker && npm run lint:worker && npm run lint:transmux",
    "clean": "find ./build ! -name 'index.html' ! -name 'favicon.png' ! -name 'build' ! -name 'style.css' ! -name 'demo.js' ! -name 'logo-white.png' -exec rm -rf {} +",
    "clippy": "cargo clippy",
    "compile:rs": "cargo build --target=wasm32-unknown-unknown",
    "compile:rs:release": "cargo build --release --target=wasm32-unknown-unknown",
    "check:wasm-abi": "node scripts/check_wasm_abi.mjs",
    "doc": "rm -rf doc/generated && docgen.ico doc build/doc",
    "fmt": "npm run fmtr && npm run fmtt",
    "fmtr": "cargo fmt",
    "fmtr:check": "cargo fmt --check",
    "fmtt": "prettier --write . --loglevel warn",
    "fmtt:check": "prettier . --check",
    "fmt:check": "npm run fmtr:check && npm run fmtt:check",
    "generate:wasm-abi": "node scripts/generate_wasm_abi_enums.mjs",
    "install:binaryen": "./scripts/install_binaryen.sh",
    "lint": "npm run lint:main && npm run lint:worker && npm run lint:transmux && npm run lint:common && npm run lint:demo",
    "lint:common": "cd src/ts-common && eslint .",
    "lint:demo": "cd demo && eslint src/**/*",
    "lint:main": "cd src/ts-main && eslint .",
    "lint:transmux": "cd src/ts-transmux && eslint .",
    "lint:worker": "cd src/ts-worker && eslint .",
    "list": "node ./scripts/list-npm-scripts.mjs",
    "move:wasm": "cp target/wasm32-unknown-unknown/debug/wasp_hls.wasm src/wasm/wasp_hls_bg.wasm && cp target/wasm32-unknown-unknown/debug/wasp_hls.wasm build/wasp_hls_bg.wasm",
    "move:wasm:release": "cp target/wasm32-unknown-unknown/release/wasp_hls.wasm src/wasm/wasp_hls_bg.wasm && cp target/wasm32-unknown-unknown/release/wasp_hls.wasm build/wasp_hls_bg.wasm",
    "prepublishOnly": "npm install && node ./scripts/check_package_exports.mjs && npm run build:release && npm run build:main:es6 && node scripts/generate_embedded_wasm.js && node scripts/generate_embedded_worker.js",
    "serve": "http-server ./build",
    "types": "npm run generate:wasm-abi && npm run types:main && npm run types:worker && npm run types:demo",
    "types:demo": "tsc --project ./demo --noEmit",
    "types:main": "npm run generate:wasm-abi && tsc --project ./src/ts-main --noEmit",
    "types:worker": "npm run generate:wasm-abi && tsc --project ./src/ts-worker --noEmit"
  },
  "author": "peaberberian",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "docgen.ico": "^0.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  }
}
