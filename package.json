{
  "name": "wasp-hls",
  "version": "0.4.2",
  "description": "WebAssembly HLS Player Proof Of Concept",
  "type": "module",
  "main": "build/es6/ts-main/index.js",
  "types": "build/es6/ts-main/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/es6/ts-main/index.d.ts",
      "default": "./build/es6/ts-main/index.js"
    },
    "./wasm": {
      "types": "./build/embedded/wasm.d.ts",
      "default": "./build/embedded/wasm.js"
    },
    "./worker": {
      "types": "./build/embedded/worker.d.ts",
      "default": "./build/embedded/worker.js"
    }
  },
  "files": [
    "build/",
    "doc/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/tasks/index.mjs build --release",
    "check": "node scripts/tasks/index.mjs check",
    "check:demo": "node scripts/tasks/index.mjs check demo",
    "check:main": "node scripts/tasks/index.mjs check main",
    "check:worker": "node scripts/tasks/index.mjs check worker",
    "check:fmt": "node scripts/tasks/index.mjs check fmt",
    "check:rust": "node scripts/tasks/index.mjs check rust",
    "clean": "node scripts/tasks/index.mjs clean",
    "demo": "node scripts/tasks/index.mjs build demo",
    "demo:release": "node scripts/tasks/index.mjs build demo --release",
    "docs": "node scripts/tasks/index.mjs build docs",
    "fmt": "node scripts/tasks/index.mjs fmt",
    "generate": "node scripts/tasks/index.mjs generate",
    "install:binaryen": "./scripts/install_binaryen.sh",
    "list": "node scripts/list-npm-scripts.mjs",
    "package": "node scripts/tasks/index.mjs build package",
    "scripts": "node scripts/list-npm-scripts.mjs",
    "serve": "http-server ./build",
    "start": "node scripts/tasks/index.mjs build demo --watch"
  },
  "scripts-list": {
    "Build": {
      "build": "Build the main hosted library artifacts in release mode.",
      "demo": "Build the demo and its runtime dependencies in debug mode.",
      "demo:release": "Build the demo and its runtime dependencies in release mode.",
      "docs": "Build the documentation site.",
      "package": "Build the npm package artifact tree."
    },
    "Checks": {
      "check": "Run the standard TypeScript checks for the repo.",
      "check:main": "Typecheck and lint the main-thread TypeScript code.",
      "check:worker": "Typecheck and lint the worker and transmux TypeScript code.",
      "check:demo": "Typecheck and lint the demo app.",
      "check:fmt": "Check Rust and JS/TS/Markdown formatting.",
      "check:rust": "Run clippy on the Rust code."
    },
    "Development": {
      "start": "Watch and rebuild the demo during development.",
      "serve": "Serve the build directory over HTTP.",
      "scripts": "Open the interactive npm script picker."
    },
    "Maintenance": {
      "fmt": "Format Rust and JS/TS/Markdown sources.",
      "generate": "Regenerate wasm ABI enums.",
      "clean": "Remove build artifacts.",
      "install:binaryen": "Install a local Binaryen toolchain under ./tmp/binaryen."
    }
  },
  "author": "peaberberian",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "docgen.ico": "^0.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  }
}
