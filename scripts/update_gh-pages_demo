#!/bin/bash

# ============= update_gh-pages_demo =============
#
# Builds the demo and docs, updates a temporary `gh-pages` worktree with the
# freshly built artifacts, and offers to commit/push them.

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  cat <<'EOF'
Usage: ./scripts/update_gh-pages_demo

Run from a clean `main` checkout to rebuild the demo/docs and deploy them to
the `gh-pages` branch.
EOF
  exit 0
fi

set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

tmpDemoDir=""
tmpGhPagesDir=""

cleanup() {
  if [ -n "$tmpGhPagesDir" ] && [ -d "$tmpGhPagesDir" ]; then
    git worktree remove --force "$tmpGhPagesDir" >/dev/null 2>&1 || true
  fi
  if [ -n "$tmpDemoDir" ] && [ -d "$tmpDemoDir" ]; then
    rm -rf "$tmpDemoDir"
  fi
}

trap cleanup EXIT

current_branch=$(git branch | sed -n -e 's/^\* \(.*\)/\1/p')

if ! [ "$current_branch" == "main" ]; then
  echo $current_branch
  echo "ERROR: The current branch should be main"
  exit 1;
fi

# Generate demo
npm install
npm run demo -- --release
npm run docs

if [ -n "$(git status --porcelain)" ]; then
  echo "ERROR: Please commit your modifications to main"
  exit 1;
fi

tmpDemoDir=$(mktemp -d)
tmpGhPagesDir=$(mktemp -d)

cp -r build/. "$tmpDemoDir/" -v

# update gh-pages in an isolated worktree so the current checkout stays intact
git worktree add --force "$tmpGhPagesDir" gh-pages

(
  cd "$tmpGhPagesDir"
  git pull origin gh-pages
  find . -mindepth 1 -maxdepth 1 ! -name '.git' -exec rm -rf {} + || true
  cp -r "$tmpDemoDir"/. .

  if [ -n "$(git status --porcelain)" ]; then
    echo "-- Current Status on gh-pages: --"
    echo ""
    git status

    while : ; do
      echo ""
      echo "We will push the demo to gh-pages."
      REPLY=""
      read -p "do you want to continue [y/d/s/a/c/t/h] (h for help) ? " -n 1 -r
      echo ""

      if [[ $REPLY =~ ^[Hh](elp)?$ ]]; then
        echo ""
        echo ""
        echo "+- help -------------------------------------------------+"
        echo "| y: commit and continue                                 |"
        echo "| d: see diff                                            |"
        echo "| s: see status                                          |"
        echo "| a: abort script from here                              |"
        echo "| c: discard changes in the temporary gh-pages worktree  |"
        echo "| t: stash this commit in the temporary gh-pages worktree|"
        echo "| h: see this help                                       |"
        echo "+--------------------------------------------------------+"
      elif [[ $REPLY =~ ^[Yy](es)?$ ]]; then
        git add --all
        git commit -m "demo: deploy to the gh-pages" -S
        git push origin gh-pages
        break
      elif [[ $REPLY =~ ^[Dd](iff)?$ ]]; then
        git diff || true # ignore when return 1
      elif [[ $REPLY =~ ^[Ss](tatus)?$ ]]; then
        git status
      elif [[ $REPLY =~ ^[Aa](bort)?$ ]]; then
        echo "exiting"
        exit 0
      elif [[ $REPLY =~ ^[Cc](heckout)?$ ]]; then
        git restore --source=HEAD --staged --worktree .
      elif [[ $REPLY =~ ^([Tt]|([Ss]tash))?$ ]]; then
        git stash -u push
        break
      fi
    done
  else
    echo "nothing to do on the gh-pages branch"
  fi
)

echo "current checkout left on $current_branch"
